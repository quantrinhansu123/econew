# Supabase no IPv4 add-on / IPv6-incompatible networks:
# Use Session pooler from Supabase Dashboard > Connect > Connection Pooler.
# This is the recommended runtime URL for persistent NestJS/TypeORM servers when direct IPv6 is unavailable.
SUPABASE_POOLER_DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Optional fallback for IPv6-capable environments or Supabase IPv4 add-on only.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DB_POOL_MAX=5
DB_MIGRATION_POOL_MAX=1
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=10000
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
# Dev: tăng lên 8h để tránh bị đăng xuất liên tục khi làm việc lâu (production nên giữ 15m–1h)
JWT_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
# Thêm origin tùy chỉnh (dev/staging). Production Vercel (eco-webapp.vercel.app) đã được allow sẵn trong code.
CORS_ORIGIN=http://localhost:6060,http://127.0.0.1:6060,http://localhost:5173
PORT=3001

