# Production Vercel (eco-webapp.vercel.app): để trống — client gọi /api/v1 cùng origin (vercel.json rewrite → server/api).
# Chỉ set khi frontend và backend deploy tách project:
# VITE_API_URL=https://your-backend.vercel.app/api/v1

# Dev local: KHÔNG bật direct — dùng Vite proxy /api → backend (đọc PORT từ server/.env)
# VITE_API_URL_DIRECT=true
